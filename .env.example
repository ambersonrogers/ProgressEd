# ==========================
# Base / Render / Backend
# ==========================
NODE_ENV=production
PORT=5000

# PostgreSQL (Render)
# Exemplo: postgres://USER:PASSWORD@HOST:5432/progress-ed-db?sslmode=require
DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/progress-ed-db?sslmode=require

# JWT (caso mantenha endpoints atuais ou use para testes)
JWT_SECRET=replace_me

# ==========================
# Supabase
# ==========================
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Se usar service role (apenas backend)
# SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# ==========================
# OAuth (Google + Microsoft)
# (Usado por Supabase/NextAuth)
# ==========================
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET

MICROSOFT_CLIENT_ID=YOUR_MICROSOFT_CLIENT_ID
MICROSOFT_CLIENT_SECRET=YOUR_MICROSOFT_CLIENT_SECRET

# ==========================
# NextAuth
# ==========================
NEXTAUTH_SECRET=replace_me
NEXTAUTH_URL=http://localhost:3000

