# Configuração de Ambiente para ProgressEd
# Este arquivo contém configurações para diferentes plataformas

# Plataformas Suportadas:
# - web: Navegador (React + Vite)
# - desktop: Electron (Aplicação Desktop)
# - mobile: React Native (iOS/Android)
# - docker: Containerizado (Docker)
# - kubernetes: Orquestração (K8s)

# Arquivo de exemplo: .env.platform

# ============= AMBIENTE =============
NODE_ENV=development
# Opções: development, staging, production

# ============= PLATAFORMA =============
VITE_PLATFORM=web
# Opções: web, desktop, mobile, docker, kubernetes

# ============= API =============
VITE_API_URL=http://localhost:5000/api
VITE_API_TIMEOUT=30000

# ============= AUTENTICAÇÃO =============
VITE_JWT_STORAGE=localStorage
# Opções: localStorage, sessionStorage, secure (apenas HTTPS)

# ============= CONEXÃO =============
VITE_SOCKET_URL=http://localhost:5000
VITE_SOCKET_ENABLED=false

# ============= FEATURES =============
VITE_OFFLINE_MODE=true
VITE_PWA_ENABLED=true
VITE_SERVICE_WORKER=true

# ============= ANALYTICS =============
VITE_ANALYTICS_ENABLED=false
VITE_GA_ID=

# ============= DATABASE =============
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/progressd
DB_NAME=progressd
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# ============= JWT =============
JWT_SECRET=sua-chave-secreta-super-segura-mude-em-producao
JWT_EXPIRY=7d

# ============= CORS =============
CORS_ORIGIN=http://localhost:3000,http://localhost:5173

# ============= LOGGING =============
LOG_LEVEL=debug
# Opções: error, warn, info, debug, trace

# ============= CACHE =============
CACHE_ENABLED=true
CACHE_TTL=3600

# ============= EMAIL (Opcional) =============
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@progressd.com

# ============= AWS (Opcional) =============
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=

# ============= SEGURANÇA =============
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_MS=900000

# ============= VERSION =============
APP_VERSION=1.0.0
BUILD_DATE=
BUILD_NUMBER=
